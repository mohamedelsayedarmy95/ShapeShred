{
  "name": "@shapeshred/notification-service",
  "version": "1.0.0",
  "description": "Notification Service (Push, Email, SMS)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/bull": "^10.0.1",
    "bull": "^4.12.0",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "@sendgrid/mail": "^8.1.0",
    "twilio": "^4.19.3",
    "firebase-admin": "^12.0.0",
    "@shapeshred/shared": "*"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}

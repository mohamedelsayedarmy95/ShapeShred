{
  "name": "shapeshred-backend",
  "version": "1.0.0",
  "description": "ShapeShred Backend - Microservices Architecture",
  "private": true,
  "workspaces": [
    "auth-service",
    "user-service",
    "workout-service",
    "nutrition-service",
    "coach-service",
    "ai-service",
    "notification-service",
    "payment-service",
    "analytics-service",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:services",
    "install:services": "npm install --workspaces",
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev --workspaces\"",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.ts\"",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
